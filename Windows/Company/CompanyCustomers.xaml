<Window x:Class="Project_JustDrive.Windows.Company.CompanyCustomers"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Klanten"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButton}" Content="🏠   Dashboard"
                            Click="Dashboard_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="🚗   Mijn auto's"
                            Click="MijnAutos_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="📅   Reservaties"
                            Click="Reservaties_Click"/>
                    <Button Style="{StaticResource NavButtonActive}" Content="👥   Klanten"/>
                    <Button Style="{StaticResource NavButton}" Content="🔧   Schaderapport"
                            Click="Schade_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0" Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <TextBlock Text="Klantgeschiedenis" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Klantenlijst -->
                <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderLight}"
                        BorderThickness="0,0,1,0">
                    <StackPanel>
                        <TextBlock Text="Klanten" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource TextPrimary}" Margin="20,20,20,12"/>
                        <ListBox x:Name="KlantenList" BorderThickness="0"
                                 SelectionChanged="KlantenList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8,6">
                                        <TextBlock Text="{Binding KlantNaam}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Email}" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Geschiedenis van geselecteerde klant -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28">
                        <TextBlock x:Name="TxtKlantNaam" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtKlantEmail" Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Reservatiegeschiedenis" FontWeight="Bold" FontSize="16"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

                        <DataGrid x:Name="GeschiedenisGrid" AutoGenerateColumns="False"
                                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                                  BorderThickness="0" Background="Transparent"
                                  RowBackground="Transparent" AlternatingRowBackground="#F9FAFB"
                                  HeadersVisibility="Column" CanUserDeleteRows="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Auto" Binding="{Binding AutoNaam}" Width="*"/>
                                <DataGridTextColumn Header="Van" Binding="{Binding StartDate}" Width="*"/>
                                <DataGridTextColumn Header="Tot" Binding="{Binding EndDate}" Width="*"/>
                                <DataGridTextColumn Header="Totaal" Binding="{Binding TotalPrice, StringFormat='€{0}'}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>