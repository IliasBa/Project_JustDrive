<Window x:Class="Project_JustDrive.Windows.Company.AddCar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Auto toevoegen"
        Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,30">

            <TextBlock Text="Auto toevoegen" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column -->
                <StackPanel Grid.Column="0">

                    <!-- Merk -->
                    <TextBlock Text="Merk" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbMerk" Style="{StaticResource InputCombo}"
                              SelectionChanged="CmbMerk_SelectionChanged"/>
                    <StackPanel x:Name="PanelNieuwMerk" Visibility="Collapsed" Margin="0,0,0,4">
                        <TextBox x:Name="TxtNieuwMerk" Style="{StaticResource InputField}"
                                 Margin="0" Height="34"/>
                        <Button Content="+ Toevoegen" Style="{StaticResource PrimaryButton}"
                                Padding="10,5" FontSize="12" Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                Click="BtnMerkToevoegen_Click"/>
                    </StackPanel>
                    <Button Content="+ Nieuw merk" Style="{StaticResource LinkButton}"
                            Margin="0,0,0,16" HorizontalAlignment="Left"
                            Click="BtnNieuwMerk_Click"/>

                    <!-- Model -->
                    <TextBlock Text="Model" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbModel" Style="{StaticResource InputCombo}"/>
                    <StackPanel x:Name="PanelNieuwModel" Visibility="Collapsed" Margin="0,0,0,4">
                        <TextBox x:Name="TxtNieuwModel" Style="{StaticResource InputField}"
                                 Margin="0" Height="34"/>
                        <Button Content="+ Toevoegen" Style="{StaticResource PrimaryButton}"
                                Padding="10,5" FontSize="12" Margin="0,4,0,0"
                                HorizontalAlignment="Left"
                                Click="BtnModelToevoegen_Click"/>
                    </StackPanel>
                    <Button Content="+ Nieuw model" Style="{StaticResource LinkButton}"
                            Margin="0,0,0,16" HorizontalAlignment="Left"
                            Click="BtnNieuwModel_Click"/>

                    <!-- Type -->
                    <TextBlock Text="Type" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbType" Style="{StaticResource InputCombo}" Margin="0,0,0,16">
                        <ComboBoxItem Content="Hatchback"/>
                        <ComboBoxItem Content="Sedan"/>
                        <ComboBoxItem Content="SUV"/>
                        <ComboBoxItem Content="Minivan"/>
                    </ComboBox>

                    <!-- Brandstof -->
                    <TextBlock Text="Brandstof" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbBrandstof" Style="{StaticResource InputCombo}" Margin="0,0,0,16">
                        <ComboBoxItem Content="Gasoline"/>
                        <ComboBoxItem Content="Diesel"/>
                        <ComboBoxItem Content="Electric"/>
                        <ComboBoxItem Content="Hybrid"/>
                    </ComboBox>

                    <!-- Transmissie -->
                    <TextBlock Text="Transmissie" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbTransmissie" Style="{StaticResource InputCombo}" Margin="0,0,0,16">
                        <ComboBoxItem Content="Manual"/>
                        <ComboBoxItem Content="Automatic"/>
                    </ComboBox>

                </StackPanel>

                <!-- Right column -->
                <StackPanel Grid.Column="2">

                    <TextBlock Text="Prijs per dag (€)" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtPrijs" Style="{StaticResource InputField}"/>

                    <TextBlock Text="Borg (€)" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtBorg" Style="{StaticResource InputField}"/>

                    <TextBlock Text="Verbruik per 100km" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtVerbruik" Style="{StaticResource InputField}"/>

                    <TextBlock Text="Nummerplaat" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtNummerplaat" Style="{StaticResource InputField}"/>

                </StackPanel>
            </Grid>

            <Button Content="Auto toevoegen" Style="{StaticResource PrimaryButton}"
                    Width="200" HorizontalAlignment="Right" Margin="0,8,0,0"
                    Click="BtnOpslaan_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>