<Window x:Class="Project_JustDrive.Windows.Company.CompanyDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Bedrijf Dashboard"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="20" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButtonActive}" Content="🏠   Dashboard"/>
                    <Button Style="{StaticResource NavButton}" Content="🚗   Mijn auto's"
                            Click="MijnAutos_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="📅   Reservaties"
                            Click="Reservaties_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="👥   Klanten"
                            Click="Klanten_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="🔧   Schaderapport"
                            Click="Schade_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Border Background="{StaticResource SidebarBgAlt}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Accent}">
                                <TextBlock x:Name="TxtInitiaal" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtBedrijfNaam" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtEmail" Foreground="#8A95A8" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0" Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <TextBlock x:Name="TxtWelkom" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,28">

                    <!-- Statistieken -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Totaal auto's" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                                <TextBlock x:Name="TxtTotaalAutos" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Actieve reservaties" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                                <TextBlock x:Name="TxtActieveReservaties" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="Schaderapport" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                                <TextBlock x:Name="TxtSchade" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Totale omzet" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                                <TextBlock x:Name="TxtOmzet" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Recente reservaties -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Recente reservaties" FontWeight="Bold" FontSize="16"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <Button Grid.Column="1" Content="Alle bekijken"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="Reservaties_Click"/>
                                <Button Content="Exporteer data naar CSV" 
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,10,0"
                                        Click="ExportCSV_Click"/>
                            </Grid>

                            <DataGrid x:Name="RecenteReservaties" AutoGenerateColumns="False"
                                      IsReadOnly="True" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" Background="Transparent"
                                      RowBackground="Transparent" AlternatingRowBackground="#F9FAFB"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ReservationId" Binding="{Binding ReservatieId, StringFormat='# {0}'}" Width="*"/>
                                    <DataGridTextColumn Header="Klant" Binding="{Binding KlantNaam}" Width="*"/>
                                    <DataGridTextColumn Header="Auto" Binding="{Binding AutoNaam}" Width="*"/>
                                    <DataGridTextColumn Header="Van" Binding="{Binding StartDate}" Width="*"/>
                                    <DataGridTextColumn Header="Tot" Binding="{Binding EndDate}" Width="*"/>
                                    <DataGridTextColumn Header="Totaal" Binding="{Binding TotalPrice, StringFormat='€{0}'}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>