<Window x:Class="Project_JustDrive.Windows.Company.EditCar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Auto bewerken"
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,30">

            <TextBlock Text="Auto bewerken" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,24"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Merk" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtMerk" Style="{StaticResource InputField}" IsReadOnly="True"
                             Background="#F5F6F8"/>

                    <TextBlock Text="Model" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtModel" Style="{StaticResource InputField}" IsReadOnly="True"
                             Background="#F5F6F8"/>

                    <TextBlock Text="Type" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbType" Style="{StaticResource InputCombo}">
                        <ComboBoxItem Content="Hatchback"/>
                        <ComboBoxItem Content="Sedan"/>
                        <ComboBoxItem Content="SUV"/>
                        <ComboBoxItem Content="Minivan"/>
                    </ComboBox>

                    <TextBlock Text="Brandstof" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbBrandstof" Style="{StaticResource InputCombo}">
                        <ComboBoxItem Content="Gasoline"/>
                        <ComboBoxItem Content="Diesel"/>
                        <ComboBoxItem Content="Electric"/>
                        <ComboBoxItem Content="Hybrid"/>
                    </ComboBox>

                    <TextBlock Text="Transmissie" Style="{StaticResource InputLabel}"/>
                    <ComboBox x:Name="CmbTransmissie" Style="{StaticResource InputCombo}">
                        <ComboBoxItem Content="Manual"/>
                        <ComboBoxItem Content="Automatic"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Prijs per dag (€)" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtPrijs" Style="{StaticResource InputField}"/>

                    <TextBlock Text="Borg (€)" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtBorg" Style="{StaticResource InputField}"/>

                    <TextBlock Text="Verbruik per 100km" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtVerbruik" Style="{StaticResource InputField}"/>

                    <TextBlock Text="Nummerplaat" Style="{StaticResource InputLabel}"/>
                    <TextBox x:Name="TxtNummerplaat" Style="{StaticResource InputField}"/>
                    
                </StackPanel>
                
            </Grid>

            <!-- Photo upload -->
            <TextBlock Text="Foto" Style="{StaticResource InputLabel}" Margin="0,8,0,4"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Height="120" Background="#1F2937" 
                    CornerRadius="8" ClipToBounds="True">
                    <Image x:Name="ImgPreview" Stretch="UniformToFill"
                     VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <Button Grid.Column="2" Content="📁  Foto kiezen" 
                        Style="{StaticResource PrimaryButton}"
                         VerticalAlignment="Center"
                        Click="BtnFotoKiezen_Click"/>
            </Grid>

            <Button Content="Opslaan" Style="{StaticResource PrimaryButton}"
                    Width="200" HorizontalAlignment="Right" Margin="0,8,0,0"
                    Click="BtnOpslaan_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>