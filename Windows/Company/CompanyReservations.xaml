<Window x:Class="Project_JustDrive.Windows.Company.CompanyReservations"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Reservaties"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButton}" Content="🏠   Dashboard" Click="Dashboard_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="🚗   Mijn auto's" Click="MijnAutos_Click"/>
                    <Button Style="{StaticResource NavButtonActive}" Content="📅   Reservaties"/>
                    <Button Style="{StaticResource NavButton}" Content="👥   Klanten" Click="Klanten_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="🔧   Schaderapport" Click="Schade_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0" Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Reservaties" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="TxtAantal" FontSize="13"
                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Statistieken -->
            <Grid Grid.Row="1" Margin="32,20,32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Totaal" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock x:Name="TxtTotaal" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Actief" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock x:Name="TxtActief" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Afgerond" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock x:Name="TxtAfgerond" FontSize="28" FontWeight="Bold"
                                   Foreground="#10B981" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Reservatie kaarten -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="32,20,32,20">
                <ItemsControl x:Name="ReservationsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icoon -->
                                    <Border Grid.Column="0" Width="45" Height="45" CornerRadius="10"
                                            Background="#FFF5F0" Margin="0,0,16,0">
                                        <TextBlock Text="📅" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Klant -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Klant" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding KlantNaam}" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- Auto -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Auto" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding AutoNaam}" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- Datum -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="Periode" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock FontSize="13" Foreground="{StaticResource TextPrimary}">
                                            <Run Text="{Binding StartDate}"/>
                                            <Run Text=" → "/>
                                            <Run Text="{Binding EndDate}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Prijs -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="16,0">
                                        <TextBlock Text="Totaal" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding TotalPrice, StringFormat='€{0}'}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- Status badge -->
                                    <Border Grid.Column="5" CornerRadius="20" Padding="12,6"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Actief">
                                                        <Setter Property="Background" Value="#FFF5F0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Actief">
                                                            <Setter Property="Foreground" Value="#F26B1F"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>