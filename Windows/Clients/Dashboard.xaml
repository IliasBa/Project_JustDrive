<Window x:Class="Project_JustDrive.Windows.Clients.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:Project_JustDrive"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Dashboard"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <!-- Sidebar nav button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Primary (orange) button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="20" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButtonActive}" Content="🏠   Home"/>
                    <Button Style="{StaticResource NavButton}" Content="🚗   Huur auto"
                            Click="HuurAuto_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="♥    Favorieten"
                            />
                    <Button Style="{StaticResource NavButton}" Content="📅   Mijn reservaties"/>
                    <Button Style="{StaticResource NavButton}" Content="👤   Profiel"/>
                </StackPanel>

                <!-- User card + logout -->
                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Border Background="{StaticResource SidebarBgAlt}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Accent}">
                                <TextBlock Text="Y" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Younes" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock Text="younes@gmail.com" Foreground="#8A95A8" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0"
                            Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ MAIN CONTENT ============ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" Padding="32,18" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F5F6F8" CornerRadius="8" Padding="14,10" MaxWidth="700" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                            <TextBlock Text="Zoek naar je droomauto..." Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="👤" FontSize="14" Foreground="{StaticResource Accent}" Margin="0,0,8,0"/>
                        <TextBlock Text="Younes" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,28">

                    <!-- Welcome header -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Welkom terug, Younes" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Actieve reservatie" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="14,10" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Je hebt 1 actieve reservatie" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Je hebt 3 vorige reservaties" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Active reservation card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Actieve reservatie" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="140" Height="90" CornerRadius="8" Background="#1F2937"/>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="BMW M3" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="20-03 → 25-03" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="€ 120" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                    <Button Content="Bekijk details" Style="{StaticResource PrimaryButton}" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Previous reservations card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Vorige reservaties" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                            <!-- Audi Q5 -->
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="100" Height="70" CornerRadius="8" Background="#FCD34D"/>
                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Audi Q5" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="€ 90 / dag" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="€ 90" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                    <Button Content="Opnieuw huren" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Tesla Model 3 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="100" Height="70" CornerRadius="8" Background="#E5E7EB"/>
                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tesla Model 3" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="€ 110 / dag" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="€ 110" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                    <Button Content="Opnieuw huren" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
