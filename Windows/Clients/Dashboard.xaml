<Window x:Class="Project_JustDrive.Windows.Clients.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:Project_JustDrive"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Dashboard"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <!-- Sidebar nav button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Primary (orange) button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="20" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButtonActive}" Content="🏠   Home"/>
                    <Button Style="{StaticResource NavButton}" Content="🚗   Huur auto"
                            Click="HuurAuto_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="♥    Favorieten" Click="Favorite_Click"
                            />

                    <Button Style="{StaticResource NavButton}" Content="👤   Profiel" Click ="Profiel_Click" />
                </StackPanel>

                <!-- User card + logout -->
                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Border Background="{StaticResource SidebarBgAlt}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Accent}">
                                <TextBlock x:Name="txtProfileInitials" Text="" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtProfileName" Text="" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtProfileEmaill" Text="" Foreground="#8A95A8" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0"
                            Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ MAIN CONTENT ============ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" Padding="32,18" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F5F6F8" CornerRadius="8" Padding="14,10" MaxWidth="700" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                            <TextBlock Text="Zoek naar reservaties... " Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="32,28">

                    <!-- Welcome header -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="txtWelcome" Text="Welkom, " FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <!--<Border Grid.Column="1" Background="White" CornerRadius="8" Padding="14,10" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                            --><!--<StackPanel>
                                <TextBlock Text="Je hebt 1 actieve reservatie" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Je hebt 3 vorige reservaties" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>--><!--
                        </Border>-->
                    </Grid>

                    <!-- Active reservation card -->
                    <!--<Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Actieve reservatie" FontWeight="Bold" FontSize="16" 
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="140" Height="90" CornerRadius="8" Background="#1F2937"/>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtActiveCarName" FontSize="20" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock x:Name="txtActiveDateRange" Foreground="{StaticResource TextMuted}" 
                           Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock x:Name="txtActivePrice" FontSize="20" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" 
                               VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                    <Button Content="Bekijk details" Style="{StaticResource PrimaryButton}" 
                        Margin="0,10,0,0" Click="BekijkDetails_Click"/>
                                    <Button Content="Schade melden"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,10,0,0"
                                        Click="SchadeMelden_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>-->

                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Actieve reservatie" FontWeight="Bold" FontSize="16" 
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                            <Grid x:Name="gridActiveReservation">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="140" Height="90" CornerRadius="8" Background="#1F2937"/>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="txtActiveCarName" FontSize="20" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock x:Name="txtActiveDateRange" Foreground="{StaticResource TextMuted}" 
                           Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock x:Name="txtActivePrice" FontSize="20" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" 
                               VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                    </StackPanel>
                                    <Button Content="Bekijk details" Style="{StaticResource PrimaryButton}" 
                        Margin="0,10,0,0" Click="BekijkDetails_Click"/>
                                    <Button Content="Schade melden" Style="{StaticResource PrimaryButton}" 
                        Margin="0,6,0,0" Background="#E53E3E" Click="SchadeMelden_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- No active reservation -->
                            <StackPanel x:Name="stackNoActive" Visibility="Collapsed" HorizontalAlignment="Center">
                                <TextBlock Text="Geen actieve reservatie" Foreground="{StaticResource TextMuted}" 
                                 FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Toekomstige reservaties" FontWeight="Bold" FontSize="16" 
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                            <ItemsControl x:Name="FutureReservationsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="100" Height="70" 
                                CornerRadius="8" Background="LightGray"/>

                                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CarName}" FontSize="16" 
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="{Binding DateRange}" 
                                       Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Price}" FontSize="16" FontWeight="Bold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" 
                                           VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                                </StackPanel>
                                                <Button Content="Annuleren" Style="{StaticResource PrimaryButton}" 
                                                Background="#E53E3E" Margin="0,8,0,0"
                                                Click="AnnuleerReservatie_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- ← outside the DataTemplate, below the ItemsControl -->
                            <StackPanel x:Name="stackNoFuture" Visibility="Collapsed" HorizontalAlignment="Center">
                                <TextBlock Text="Geen toekomstige reservaties" 
                                    Foreground="{StaticResource TextMuted}" 
                                    HorizontalAlignment="Right" Margin="0,0,0,12"/>
                                <Button Content="Huur een auto" Style="{StaticResource PrimaryButton}" 
                                      HorizontalAlignment="Center" Click="HuurAuto_Click"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                    <!-- Previous reservations card -->
                    <Border x:Name="stkpPreviousReservations" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Vorige reservaties" FontWeight="Bold" FontSize="16" 
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                            <ItemsControl x:Name="PreviousReservationsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="100" Height="70" 
                                CornerRadius="8" Background="LightGray"/>

                                            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CarName}" FontSize="16" 
                                                    FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="{Binding DateRange}" 
                                                    Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                                <!--<TextBlock Text="{Binding PricePerDayFormatted}" 
                                                     Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>-->
                                            </StackPanel>


                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding PricePerDayFormatted}" FontSize="20" FontWeight="Bold" 
                                                        Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text=" / dag" Foreground="{StaticResource TextMuted}" 
                                                        VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                                </StackPanel>
                                                <Button Content="Opnieuw huren" Style="{StaticResource PrimaryButton}" 
                                                    Click="RentAgain_Click" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
