<Window x:Class="Project_JustDrive.Windows.Clients.ReportDamage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schade melden"
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>

        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- Back button -->
        <Button Content="← Terug"
                Style="{StaticResource PrimaryButton}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="20"
            Padding="10,5"
            Click="Terug_Click"/>
            
        
        <Border Style="{StaticResource Card}"
            Width="450"
             Margin="0,50,0,30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Schade melden"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,20"/>

                <TextBlock Text="Schadeniveau"  Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                <ComboBox x:Name="cmbDamageLevel" Margin="0,0,0,16" Padding="10,8" FontSize="14">
                    <ComboBoxItem Content="Lichte schade"/>
                    <ComboBoxItem Content="Matige schade"/>
                    <ComboBoxItem Content="Ernstige schade"/>
                    <ComboBoxItem Content="Total loss"/>
                </ComboBox>

                <TextBlock Text="Beschrijf de schade hoe en waar."
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,10"/>

                <TextBox x:Name="txtDescription"
                     Height="120"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="10"
                     FontSize="14"/>

                <Button Content="Schade melden"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,20,0,0"

                    Click="Melden_Click"/>
            </StackPanel>

        </Border>

    </Grid>
    
</Window>