<Window x:Class="Project_JustDrive.Windows.Clients.RentCar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Huur auto"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="ChipBg" Color="White"/>

        <!-- Sidebar nav button -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Primary (orange) button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip (white) -->
        <Style x:Key="FilterChip" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F0F1F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip (active = orange) -->
        <Style x:Key="FilterChipActive" TargetType="Button" BasedOn="{StaticResource FilterChip}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="20" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="btnHome" Style="{StaticResource NavButton}"       Content="🏠   Home"
                            Click="Dashboard_Click"/>
                    <Button Style="{StaticResource NavButtonActive}" Content="🚗   Huur auto"/>
                    <Button Style="{StaticResource NavButton}"       Content="♥    Favorieten" Click="Favorite_Click"/>
                    <Button Style="{StaticResource NavButton}"       Content="👤   Profiel" Click="Profiel_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Border Background="{StaticResource SidebarBgAlt}" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Accent}">
                                <TextBlock x:Name="txtProfileInitials" Text="" Foreground="White" FontWeight="Bold"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtProfileName" Text="" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtProfileEmaill" Text="" Foreground="#8A95A8" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0"
                            Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ MAIN CONTENT ============ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#F5F6F8" CornerRadius="8" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtZoek" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                                     Width="400" FontSize="14"
                                     TextChanged="TxtZoek_TextChanged"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" >
                <StackPanel Margin="32,28">

                    <!-- Header -->
                    <TextBlock Text="Huur een auto" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Kies uit ons uitgebreide aanbod"
                               Foreground="{StaticResource Accent}" Margin="0,4,0,20"/>

                    <!-- Filter chips -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Button Style="{StaticResource FilterChipActive}" Content="Alle"
                                Click="FilterAlle_Click"/>
                        <Button Style="{StaticResource FilterChip}"       Content="Sport"
                                Click="FilterSport_Click"/>
                        <Button Style="{StaticResource FilterChip}"       Content="SUV"
                                Click="FilterSUV_Click"/>
                        <Button Style="{StaticResource FilterChip}"       Content="Elektrisch"
                                Click="FilterElektrisch_Click"/>
                        <Button Style="{StaticResource FilterChip}"       Content="Minivan"
                                Click="FilterMinivan_Click"/>
                    </StackPanel>

                    <!-- Car grid (3 columns) -->
                    <ItemsControl x:Name="ItemsControlCars" ItemsSource="{Binding Cars}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,20,20">
                                    <StackPanel>

                                        <!-- IMAGE / TOP -->
                                        <Border Height="180" Background="#1F2937" CornerRadius="12,12,0,0">
                                            <Image Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Source" Value="{Binding ImagePath}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ImagePath}" Value="">
                                                                <Setter Property="Source" Value="{x:Null}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Border>

                                        <!-- CONTENT -->
                                        <StackPanel Margin="20">

                                            <TextBlock Text="{Binding CarBrand}" FontSize="18" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Model}" FontSize="18" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Type}" Foreground="Gray" Margin="0,2,0,10"/>

                                            <TextBlock Text="{Binding Transmission}"/>
                                            <TextBlock Text="{Binding Fuel}"/>
                                            <TextBlock Text="{Binding Zitplaatsen, StringFormat='{}👥 {0} zitplaatsen'}"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="{Binding PricePerDay, StringFormat='€{0}'}"
                                       FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text=" / dag" Margin="5,5,0,0"/>
                                            </StackPanel>

                                            <Button Content="Huur nu" Style="{StaticResource PrimaryButton}" Margin="0,10,0,0"
                                                    Click="HuurNu_Click"/>
                                            <Button Content="Vergelijk" Style="{StaticResource PrimaryButton}" 
                                                Background="#6B7280"
                                                Margin="0,6,0,0"
                                                Tag="{Binding Id}"
                                                Click="Vergelijk_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>