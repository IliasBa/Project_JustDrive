<Window x:Class="Project_JustDrive.Windows.Admin.AdminCars"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Auto's"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButton}" Content="🏠   Dashboard"
                            Click="Dashboard_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="👥   Gebruikers"
                            Click="Gebruikers_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="📅   Reservaties"
                            Click="Reservaties_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="🔧   Schaderapport"
                            Click="Schade_Click"/>
                    <Button Style="{StaticResource NavButtonActive}" Content="🚗   Auto's"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0" Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0" Background="White" Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Auto's beheren" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="TxtAantal" FontSize="13"
                                   Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FILTER BAR -->
            <Border Grid.Row="1" Background="White" Padding="32,12"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filter op bedrijf:" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,12,0"/>
                    <ComboBox x:Name="CmbBedrijf" Width="200" Height="35"
                              SelectionChanged="CmbBedrijf_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- AUTO LIJST -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="32,20">
                <ItemsControl x:Name="CarsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icoon -->
                                    <Border Grid.Column="0" Width="45" Height="45" CornerRadius="10"
                                            Background="#FFF5F0" Margin="0,0,16,0">
                                        <TextBlock Text="🚗" FontSize="20"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Auto naam -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Auto" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding AutoNaam}" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Type}" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>

                                    <!-- Bedrijf -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Bedrijf" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding BedrijfNaam}" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- Prijs -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="Prijs/dag" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding PricePerDay, StringFormat='€{0}'}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource Accent}"/>
                                    </StackPanel>

                                    <!-- Brandstof -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                        <TextBlock Text="Brandstof" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding Fuel}" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- Knoppen -->
                                    <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Button Content="Verwijderen"
                                                Style="{StaticResource DangerButton}"
                                                Click="Verwijder_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>