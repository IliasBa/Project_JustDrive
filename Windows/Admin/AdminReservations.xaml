<Window x:Class="Project_JustDrive.Windows.Admin.AdminReservations"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Reservaties"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="16" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="24,28,0,32">
                    <TextBlock Text="Just Drive" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="." Foreground="{StaticResource Accent}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavButton}" Content="🏠   Dashboard"
                            Click="Dashboard_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="👥   Gebruikers"
                            Click="Gebruikers_Click"/>
                    <Button Style="{StaticResource NavButtonActive}" Content="📅   Reservaties"/>
                    <Button Style="{StaticResource NavButton}" Content="🔧   Schaderapport"
                            Click="Schade_Click"/>
                    <Button Style="{StaticResource NavButton}" Content="🚗   Auto's"
                            Click="Autos_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Button Style="{StaticResource NavButton}" Content="⎋   Uitloggen"
                            Background="#0A1422" Margin="0" Click="Uitloggen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOPBAR -->
            <Border Grid.Row="0" Background="White" Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Reservaties beheren" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="TxtAantal" Margin="0,2,0,0" FontSize="13"
                               Foreground="{StaticResource TextMuted}" Text="0 reservaties gevonden"/>
                </StackPanel>
            </Border>

            <!-- RESERVATIONS LIST -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="32,20">
                <ItemsControl x:Name="ReservationsPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ID -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="ID" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding Id}" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource Accent}"/>
                                    </StackPanel>

                                    <!-- KLANT -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Klant" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding Klant}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- AUTO -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Auto" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding Auto}" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- VAN -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="Van" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding StartDate}" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- TOT -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                        <TextBlock Text="Tot" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding EndDate}" FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- PRIJS -->
                                    <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="16,0">
                                        <TextBlock Text="Totaal" FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding TotalPrice, StringFormat='€{0}'}"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- STATUS -->
                                    <Border Grid.Column="6" CornerRadius="20" Padding="12,6"
                                            VerticalAlignment="Center" Margin="8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Actief">
                                                        <Setter Property="Background" Value="#FFF5F0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Actief">
                                                            <Setter Property="Foreground" Value="#F26B1F"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- DELETE -->
                                    <Button Grid.Column="7" Content="Verwijderen"
                                            Width="110" Height="34"
                                            Style="{StaticResource DangerButton}"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0"
                                            Click="Verwijder_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>