<Window x:Class="Project_JustDrive.Windows.Admin.AdminUsers"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Just Drive - Gebruikers"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">

    <Window.Resources>

        <!-- COLORS -->
        <SolidColorBrush x:Key="SidebarBg" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="SidebarBgAlt" Color="#162338"/>
        <SolidColorBrush x:Key="Accent" Color="#F26B1F"/>
        <SolidColorBrush x:Key="AccentHover" Color="#D85A14"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F1B2D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E5E7EB"/>

        <!-- SIDEBAR BUTTON -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D2E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,2"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#1C2B45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ACTIVE SIDEBAR BUTTON -->
        <Style x:Key="NavButtonActive"
               TargetType="Button"
               BasedOn="{StaticResource NavButton}">

            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="PrimaryButton" TargetType="Button">

            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton" TargetType="Button">

            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CARD -->
        <Style x:Key="CardStyle" TargetType="Border">

            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>

            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                                      Opacity="0.06"
                                      BlurRadius="16"
                                      ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBg}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="24,28,0,32">

                    <TextBlock Text="Just Drive"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="."
                               Foreground="{StaticResource Accent}"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- NAVIGATION -->
                <StackPanel Grid.Row="1">

                    <Button Style="{StaticResource NavButton}"
                            Content="🏠   Dashboard"
                            Click="Dashboard_Click"/>

                    <Button Style="{StaticResource NavButtonActive}"
                            Content="👥   Gebruikers"/>

                    <Button Style="{StaticResource NavButton}"
                            Content="📅   Reservaties"
                            Click="Reservaties_Click"/>

                    <Button Style="{StaticResource NavButton}"
                            Content="🔧   Schaderapport"
                            Click="Schade_Click"/>

                    <Button Style="{StaticResource NavButton}"
                            Content="🚗   Auto's"
                            Click="Autos_Click"/>

                </StackPanel>

                <!-- LOGOUT -->
                <StackPanel Grid.Row="2"
                            Margin="12,0,12,16">

                    <Button Style="{StaticResource NavButton}"
                            Content="⎋   Uitloggen"
                            Background="#0A1422"
                            Margin="0"
                            Click="Uitloggen_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0"
                    Background="White"
                    Padding="32,18"
                    BorderBrush="{StaticResource BorderLight}"
                    BorderThickness="0,0,0,1">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>

                        <TextBlock Text="Gebruikers beheren"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>

                        <TextBlock x:Name="TxtAantal"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- FILTERS -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">

                        <Button Content="Alle"
                                Margin="0,0,8,0"
                                Padding="16,8"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Background="{StaticResource Accent}"
                                Foreground="White"
                                BorderThickness="0"
                                Click="FilterAlle_Click"/>

                        <Button Content="Klanten"
                                Margin="0,0,8,0"
                                Padding="16,8"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Background="White"
                                Foreground="{StaticResource TextPrimary}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderLight}"
                                Click="FilterKlant_Click"/>

                        <Button Content="Bedrijven"
                                Padding="16,8"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                Background="White"
                                Foreground="{StaticResource TextPrimary}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource BorderLight}"
                                Click="FilterBedrijf_Click"/>

                    </StackPanel>

                </Grid>
            </Border>

            <!-- USERS -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="32,20,32,20">

                <ItemsControl x:Name="UsersPanel">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <Border Style="{StaticResource CardStyle}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- AVATAR -->
                                    <Border Grid.Column="0"
                                            Width="45"
                                            Height="45"
                                            CornerRadius="23"
                                            Background="{StaticResource Accent}"
                                            Margin="0,0,16,0">

                                        <TextBlock Text="{Binding Initiaal}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="16"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- EMAIL -->
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="Email"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>

                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- NAME -->
                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="Naam"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>

                                        <TextBlock Text="{Binding Naam}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- CITY -->
                                    <StackPanel Grid.Column="3"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="Stad"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"/>

                                        <TextBlock Text="{Binding City}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>

                                    <!-- ROLE -->
                                    <Border Grid.Column="4"
                                            CornerRadius="20"
                                            Padding="12,6"
                                            VerticalAlignment="Center"
                                            Margin="16,0">

                                        <Border.Style>
                                            <Style TargetType="Border">

                                                <Setter Property="Background"
                                                        Value="#FFF5F0"/>

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Role}"
                                                                 Value="company">

                                                        <Setter Property="Background"
                                                                Value="#EFF6FF"/>
                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding Role}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">

                                            <TextBlock.Style>

                                                <Style TargetType="TextBlock">

                                                    <Setter Property="Foreground"
                                                            Value="#F26B1F"/>

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding Role}"
                                                                     Value="company">

                                                            <Setter Property="Foreground"
                                                                    Value="#2563EB"/>
                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>

                                            </TextBlock.Style>

                                        </TextBlock>

                                    </Border>

                                    <!-- BUTTONS -->
                                    <StackPanel Grid.Column="5"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Margin="20,0,0,0">

                                        <Button Content="Bewerken"
                                                Width="95"
                                                Height="34"
                                                Style="{StaticResource PrimaryButton}"
                                                Margin="0,0,8,0"
                                                Click="Bewerken_Click"/>

                                        <Button Content="Verwijderen"
                                                Width="110"
                                                Height="34"
                                                Style="{StaticResource DangerButton}"
                                                Click="Verwijder_Click"/>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </Grid>

    </Grid>

</Window>