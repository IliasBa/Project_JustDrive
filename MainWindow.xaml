        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF5F0" Offset="0"/>
                <GradientStop Color="#FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="White" CornerRadius="20" Padding="50,40"
                Width="420" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="40" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <!-- Logo -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock Text="Just Drive" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="." FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"/>
                </StackPanel>
                <TextBlock Text="Log in om verder te gaan" FontSize="14"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Email -->
                <TextBlock Text="E-mailadres" Foreground="#6B7280" FontSize="13" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtEmail" Style="{StaticResource InputField}" FontSize="14" Foreground="Black" />

                <!-- Wachtwoord -->
                <TextBlock Text="Wachtwoord" Foreground="#6B7280" FontSize="13" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource InputPassword}" FontSize="20" Foreground="Black"/>

                <!-- Wachtwoord vergeten -->
                <TextBlock Text="Wachtwoord vergeten?" FontSize="13"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           Cursor="Hand"/>

                <!-- Inloggen -->
                <Button Content="Inloggen" Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,10" Click="Login_Click"/>

                <!-- Registreer -->
                <Button Content="Nog geen account? Registreer" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,16" Click="Registreren_Click"/>

                <!-- Disclaimer -->
                <TextBlock FontSize="11" Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12">
                    <Run Text="Door verder te gaan ga je akkoord met onze "/>
                    <Run Text="Algemene Voorwaarden" Foreground="{StaticResource Accent}"/>
                    <Run Text=" en "/>
                    <Run Text="Privacybeleid" Foreground="{StaticResource Accent}"/>
                </TextBlock>

            </StackPanel>
        </Border>
    </Grid>
</Window>